// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

//////////////// ENUMS ////////////////

enum Role {
  ADMIN
  STUDENT
  MENTOR
  PLACEMENT_OFFICER
}

enum Mode {
  ONLINE
  OFFLINE
  HYBRID
}

enum InternshipStatus {
  OPEN
  CLOSED
}

enum StudentInternshipStatus {
  APPLIED
  ONGOING
  REJECTED
  COMPLETED
}

//////////////// USER ////////////////

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  phoneNo    String?
  department String?
  role       Role
  profileUrl String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  student          Student?
  mentor           Mentor?
  placementOfficer PlacementOfficer?

  @@map("users")
}

//////////////// STUDENT ////////////////

model Student {
  userId           String   @id
  semester         Int?
  year             Int?
  cgpa             Decimal? @db.Decimal(3, 2)
  resumeUrl        String?
  profileCompleted Boolean  @default(false)

  mentorId String?
  mentor   Mentor? @relation(fields: [mentorId], references: [userId])

  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  internships      StudentInternship[]
  savedInternships SavedInternship[]
  skills           StudentSkill[]

  @@map("students")
}

//////////////// MENTOR ////////////////

model Mentor {
  userId          String  @id
  designation     String?
  experienceYears Int?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  students Student[]

  @@map("mentors")
}

//////////////// PLACEMENT OFFICER ////////////////

model PlacementOfficer {
  userId String @id

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  internships Internship[]

  @@map("placement_officers")
}

//////////////// INTERNSHIP ////////////////

model Internship {
  id            String           @id @default(uuid())
  title         String
  companyName   String?
  companyUrl    String?
  companyLogo   String?
  description   String?
  location      String?
  mode          Mode
  salaryPackage String?
  minCgpa       Decimal?         @db.Decimal(3, 2)
  status        InternshipStatus @default(OPEN)
  createdAt     DateTime         @default(now())

  postedById String
  postedBy   PlacementOfficer @relation(fields: [postedById], references: [userId])

  applicants StudentInternship[]
  savedBy    SavedInternship[]
  skills     InternshipSkill[]

  @@map("internships")
}

//////////////// STUDENT INTERNSHIP ////////////////

model StudentInternship {
  id             String                  @id @default(uuid())
  studentId      String
  internshipId   String
  status         StudentInternshipStatus @default(APPLIED)
  certificateUrl String?
  appliedAt      DateTime                @default(now())

  student    Student    @relation(fields: [studentId], references: [userId])
  internship Internship @relation(fields: [internshipId], references: [id])

  @@unique([studentId, internshipId])
  @@map("student_internships")
}

//////////////// SAVED INTERNSHIP ////////////////

model SavedInternship {
  studentId    String
  internshipId String
  savedAt      DateTime @default(now())

  student    Student    @relation(fields: [studentId], references: [userId])
  internship Internship @relation(fields: [internshipId], references: [id])

  @@id([studentId, internshipId])
  @@map("saved_internships")
}

//////////////// SKILLS ////////////////

model Skill {
  id   Int    @id @default(autoincrement())
  name String @unique

  students    StudentSkill[]
  internships InternshipSkill[]

  @@map("skills")
}

model StudentSkill {
  studentId String
  skillId   Int

  student Student @relation(fields: [studentId], references: [userId])
  skill   Skill   @relation(fields: [skillId], references: [id])

  @@id([studentId, skillId])
  @@map("student_skills")
}

model InternshipSkill {
  internshipId String
  skillId      Int

  internship Internship @relation(fields: [internshipId], references: [id])
  skill      Skill      @relation(fields: [skillId], references: [id])

  @@id([internshipId, skillId])
  @@map("internship_skills")
}
