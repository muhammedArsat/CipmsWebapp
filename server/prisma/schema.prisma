generator client {
  provider = "prisma-client-js"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id @default(uuid())
  name             String
  email            String            @unique
  phoneNo          String?
  department       String?
  role             Role
  profileUrl       String?
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  userId           String            @unique
  mentor           Mentor?
  placementOfficer PlacementOfficer?
  student          Student?

  @@map("users")
}

model Student {
  userId           String              @id
  semester         Int?
  year             Int?
  cgpa             Decimal?            @db.Decimal(3, 2)
  resumeUrl        String?
  profileCompleted Boolean             @default(false)
  mentorId         String?
  savedInternships SavedInternship[]
  internships      StudentInternship[]
  skills           StudentSkill[]
  mentor           Mentor?             @relation(fields: [mentorId], references: [userId])
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("students")
}

model Mentor {
  userId          String    @id
  designation     String?
  experienceYears Int?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  students        Student[]

  @@map("mentors")
}

model PlacementOfficer {
  userId      String       @id
  internships Internship[]
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("placement_officers")
}

model Internship {
  id            String              @id @default(uuid())
  title         String
  companyName   String?
  companyUrl    String?
  companyLogo   String?
  description   String?
  location      String?
  mode          Mode
  duration String
  applicationDeadline DateTime? 
  requirement    String
  salaryPackage String?
  minCgpa       Decimal?            @db.Decimal(3, 2)
  status        InternshipStatus    @default(OPEN)
  createdAt     DateTime            @default(now())
  postedById    String
  skills        InternshipSkill[]
  postedBy      PlacementOfficer    @relation(fields: [postedById], references: [userId])
  savedBy       SavedInternship[]
  applicants    StudentInternship[]

  @@map("internships")
}

model StudentInternship {
  id             String                  @id @default(uuid())
  studentId      String
  internshipId   String
  status         StudentInternshipStatus @default(APPLIED)
  certificateUrl String?
  appliedAt      DateTime                @default(now())
  internship     Internship              @relation(fields: [internshipId], references: [id])
  student        Student                 @relation(fields: [studentId], references: [userId])

  @@unique([studentId, internshipId])
  @@map("student_internships")
}

model SavedInternship {
  studentId    String
  internshipId String
  savedAt      DateTime   @default(now())
  internship   Internship @relation(fields: [internshipId], references: [id])
  student      Student    @relation(fields: [studentId], references: [userId])

  @@id([studentId, internshipId])
  @@map("saved_internships")
}

model Skill {
  id          String            @id @default(uuid())
  name        String            @unique
  internships InternshipSkill[]
  students    StudentSkill[]

  @@map("skills")
}

model StudentSkill {
  studentId String
  skillId   String
  skill     Skill   @relation(fields: [skillId], references: [id])
  student   Student @relation(fields: [studentId], references: [userId])

  @@id([studentId, skillId])
  @@map("student_skills")
}

model InternshipSkill {
  internshipId String
  skillId      String
  internship   Internship @relation(fields: [internshipId], references: [id])
  skill        Skill      @relation(fields: [skillId], references: [id])

  @@id([internshipId, skillId])
  @@map("internship_skills")
}

enum Role {
  ADMIN
  STUDENT
  MENTOR
  PLACEMENT_OFFICER
}

enum Mode {
  ONLINE
  OFFLINE
  HYBRID
}

enum InternshipStatus {
  OPEN
  CLOSED
}

enum StudentInternshipStatus {
  APPLIED
  ONGOING
  REJECTED
  COMPLETED
}
